{
  "device_serial": "",
  "gpio": {
    "start": 22,
    "cancel": 27,
    "view_logs": 17
  },
  "ui_gpio": {
    "left": 22,
    "right": 17,
    "enter": 27
  },
  "paths": {
    "logs_dir": "~/bytebite-data/logs"
  },
  "offensive": {
    "marker_dir": "/sdcard/ByteBiteDemo",
    "marker_file": "bytebite_marker.txt",
    "trace_tag": "ByteBiteDemo",
    "open_url": "https://example.com",
    "test_apk_path": "",
    "test_package": "",
    "test_activity": "",
    "collect_network": true
  },
  "forensic": {
    "logcat_tail": 1000,
    "target_package": "",
    "pull_apk": true,
    "collect_network": true,
    "root_mode": false
  },
  "forensic_analysis": {
    "enabled": true,
    "source_dir": "",
    "output_dir": "",
    "output_dir_name": "analysis",
    "investigator_report_name": "investigator_report.xlsx",
    "summary_max_items": 12,
    "copy_mode": "link_or_copy",
    "max_files": 500,
    "max_text_bytes": 1048576,
    "max_text_chars": 2200,
    "timeline_max_events_per_file": 12,
    "timeline_max_text_bytes": 524288,
    "ignore_dirs": ["analysis", "triage", "timeline", "__pycache__"],
    "high_priority_keywords": [
      "murder",
      "kill",
      "knife",
      "gun",
      "firearm",
      "bomb",
      "explosive",
      "kidnap",
      "ransom"
    ],
    "suspicious_keywords": [
      "burner",
      "encrypted",
      "vault",
      "wipe",
      "delete",
      "crypto",
      "drugs",
      "weapon",
      "hide"
    ]
  },
  "llm": {
    "enabled": false,
    "binary": "~/llama.cpp/build/bin/llama-cli",
    "model": "~/llama.cpp/models/Llama-3.2-3B-Instruct-Q4_K_M.gguf",
    "temperature": 0.2,
    "context_tokens": 256,
    "max_tokens": 96,
    "threads": 2,
    "gpu_layers": 0,
    "timeout_s": 120
  },
  "comparison": {
    "run_root_phase": true
  }
}
